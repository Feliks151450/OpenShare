{
  "name": "openshare-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:readonly": "tailwindcss -c tailwind.config.ts -i ./standalone-readonly/readonly.input.css -o ./standalone-readonly/readonly.css --minify",
    "vendor:readonly": "mkdir -p standalone-readonly/vendor && cp node_modules/marked/lib/marked.umd.js standalone-readonly/vendor/ && cp node_modules/dompurify/dist/purify.min.js standalone-readonly/vendor/",
    "preview": "vite preview"
  },
  "dependencies": {
    "dompurify": "^3.4.0",
    "lucide-vue-next": "^0.577.0",
    "marked": "^18.0.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vue-tsc": "^2.1.10"
  }
}
